# Chrome extension build config.
# Copy to chrome_extension/.env (gitignored) to override the defaults.

# API_URL — server the extension talks to. Inlined into dist/sidepanel.js
# at build time, so this is whatever URL the bundle will point at; there
# is no runtime override.
#
# By default (this file unset / variable absent), `npm run build` bundles
# the hosted Couchverse API: https://podcast-commentary-api.fly.dev
#
# Uncomment one of these to override:
#
#   # Local backend development:
#   API_URL=http://localhost:8080
#
#   # Your own self-hosted deployment:
#   API_URL=https://your-api.example.com
#
# You can also pass it inline for one-off builds, no .env needed:
#   API_URL=http://localhost:8080 npm run build
