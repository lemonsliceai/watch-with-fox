# LiveKit — realtime audio/video
# Use your LiveKit Cloud URL (e.g. wss://your-project.livekit.cloud).
LIVEKIT_URL=
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# Groq — STT (Whisper) and LLM (Llama Scout)
GROQ_API_KEY=

# ElevenLabs — TTS
ELEVEN_API_KEY=

# LemonSlice — avatar rendering
LEMONSLICE_API_KEY=

# Public base URL hosting the avatar images under `/static/<filename>`.
# Independent of the API server: by default the FastAPI process serves
# these itself (so this is typically your API's public URL), but it can
# be any public host — CDN, S3, GitHub Pages, ngrok tunnel, etc. — as
# long as the images live under `/static/`. LemonSlice Cloud fetches
# from its own servers, so `localhost` will not work.
# Leave unset to run without avatars.
# Example: AVATAR_BASE_URL=https://your-api.fly.dev
AVATAR_BASE_URL=

# PostgreSQL (Neon or local)
DATABASE_URL=

# LiveKit agent name — must match between API and agent worker.
# Use a unique name for local dev so dispatches don't collide
# with the deployed worker.
AGENT_NAME=podcast-commentary-agent-local

# FoxConfig presets to load — comma-separated list of filenames in
# src/podcast_commentary/agent/fox_configs/ (without the `.py` extension).
# Each entry becomes one on-screen persona; the **first entry is the
# primary** (the room that owns the user mic and STT pipeline).
#
# The shipping default is `alien,cat_girl`. Other presets in fox_configs/
# (e.g. `david_sacks`) are opt-in experiments — add them here to play
# with them, but they are not part of the canonical lineup.
PERSONAS=alien,cat_girl
