# LiveKit — realtime audio/video
LIVEKIT_URL=ws://localhost:7880
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# Groq — STT (Whisper) and LLM (Llama Scout)
GROQ_API_KEY=

# ElevenLabs — TTS
ELEVEN_API_KEY=

# LemonSlice — avatar rendering
LEMONSLICE_API_KEY=

# PostgreSQL (Neon or local)
DATABASE_URL=

# Avatar image URL (served by the API server)
AVATAR_URL=http://localhost:8080/static/fox_2x3.jpg

# LiveKit agent name — must match between API and agent worker.
# Use a unique name for local dev so dispatches don't collide
# with the deployed worker.
AGENT_NAME=podcast-commentary-agent-local
